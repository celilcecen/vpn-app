PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vpn
DB_SSL=false
ADMIN_SETUP_TOKEN=change-this-admin-token
BILLING_WEBHOOK_SECRET=change-this-webhook-secret
DEVICE_LIMIT=3
DEFAULT_DNS=1.1.1.1, 8.8.8.8
# Node bazında istemci IP tahsisi için başlangıç network (host kısmı otomatik artar)
VPN_NETWORK_BASE=10.50.0.0
ALLOW_PRIVATE_ENDPOINTS=false
WG_RUNTIME_ENABLED=true
WG_INTERFACE=wg0
WG_BIN=wg
