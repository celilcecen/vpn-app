{
  "expo": {
    "name": "GuardLine",
    "slug": "vpn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.celilcecen.guardlanevpn",
      "appleTeamId": "HFA597M8QF",
      "buildNumber": "26",
      "infoPlist": {
        "NSNetworkExtensionUsageDescription": "VPN tüneli oluşturmak ve trafiğinizi korumak için ağ uzantısı kullanılır.",
        "NSLocalNetworkUsageDescription": "VPN bağlantısı için ağ erişimi gerekir",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.celilcecen.guardlanevpn",
      "usesCleartextTraffic": false,
      "adaptiveIcon": {
        "backgroundColor": "#0a0a12",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "react-native-wireguard-vpn",
      "@bacons/apple-targets"
    ],
    "extra": {
      "eas": {
        "projectId": "b0126b19-8548-4204-96b8-360500dad2b0"
      }
    },
    "owner": "celilcecen"
  }
}
