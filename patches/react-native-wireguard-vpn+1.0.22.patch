+static NSString *WGTrim(id v)
+{
+  if (v == nil || v == (id)kCFNull) {
+    return @"";
+  }
+  if ([v isKindOfClass:[NSString class]]) {
+    return [(NSString *)v stringByTrimmingCharactersInSet:[NSCharacterSet whitespaceAndNewlineCharacterSet]];
+  }
+  if ([v isKindOfClass:[NSNumber class]]) {
+    return [[(NSNumber *)v stringValue] stringByTrimmingCharactersInSet:[NSCharacterSet whitespaceAndNewlineCharacterSet]];
+  }
+  return @"";
+}
+
+static NSString *WGStrFromDict(NSDictionary *c, NSArray<NSString *> *keys)
+{
+  for (NSString *k in keys) {
+    NSString *s = WGTrim(c[k]);
+    if (s.length > 0) {
+      return s;
+    }
+  }
+  return @"";
+}
+
+static NSInteger WGIntPort(id raw)
+{
+  if (raw == nil || raw == (id)kCFNull) {
+    return 0;
+  }
+  if ([raw isKindOfClass:[NSNumber class]]) {
+    return [(NSNumber *)raw integerValue];
+  }
+  if ([raw isKindOfClass:[NSString class]]) {
+    return [(NSString *)raw integerValue];
+  }
+  return 0;
+}
+
+static void WGCollectAllowedIPs(NSDictionary *c, NSMutableArray *out)
+{
+  id a = c[@"allowedIPs"];
+  if (a == nil) {
+    a = c[@"allowed_ips"];
+  }
+  if (a == nil) {
+    a = c[@"AllowedIPs"];
+  }
+  if ([a isKindOfClass:[NSString class]]) {
+    for (NSString *p in [(NSString *)a componentsSeparatedByString:@","]) {
+      NSString *t = [p stringByTrimmingCharactersInSet:[NSCharacterSet whitespaceAndNewlineCharacterSet]];
+      if (t.length > 0) {
+        [out addObject:t];
+      }
+    }
+    return;
+  }
+  if ([a isKindOfClass:[NSArray class]]) {
+    for (id o in (NSArray *)a) {
+      NSString *t = WGTrim(o);
+      if (t.length > 0) {
+        [out addObject:t];
+      }
+    }
+  }
+}
 
