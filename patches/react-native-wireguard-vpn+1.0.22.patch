+RCT_EXPORT_METHOD(connect:(id)rawConfig
+                  resolver:(RCTPromiseResolveBlock)resolve
+                  rejecter:(RCTPromiseRejectBlock)reject)
+{
+  if (rawConfig == nil || rawConfig == (id)kCFNull) {
+    reject(@"CONNECT_ERROR", @"VPN connect: config is null", nil);
+    return;
+  }
+  NSDictionary *config = nil;
+  if ([rawConfig isKindOfClass:[NSDictionary class]]) {
+    config = (NSDictionary *)rawConfig;
+  } else if ([rawConfig isKindOfClass:[NSString class]]) {
+    NSData *d = [(NSString *)rawConfig dataUsingEncoding:NSUTF8StringEncoding];
+    if (d != nil) {
+      NSError *err = nil;
+      id parsed = [NSJSONSerialization JSONObjectWithData:d options:NSJSONReadingFragmentsAllowed error:&err];
+      if ([parsed isKindOfClass:[NSDictionary class]]) {
+        config = (NSDictionary *)parsed;
+      }
+    }
+  }
+  if (config == nil) {
+    reject(@"CONNECT_ERROR",
+           [NSString stringWithFormat:@"VPN connect: expected config object, got %@", NSStringFromClass([rawConfig class])],
+           nil);
+    return;
+  }
+  [self wireGuardConnectWithDictionary:config resolver:resolve rejecter:reject];
+}
+
+RCT_EXPORT_METHOD(connectFromJSON:(NSString *)jsonString
+                  resolver:(RCTPromiseResolveBlock)resolve
+                  rejecter:(RCTPromiseRejectBlock)reject)
+{
+  if (jsonString == nil || jsonString.length == 0) {
+    reject(@"CONNECT_ERROR", @"VPN connectFromJSON: empty string", nil);
+    return;
+  }
+  NSData *d = [jsonString dataUsingEncoding:NSUTF8StringEncoding];
+  NSError *err = nil;
+  id parsed = [NSJSONSerialization JSONObjectWithData:d options:NSJSONReadingFragmentsAllowed error:&err];
+  if (![parsed isKindOfClass:[NSDictionary class]]) {
+    reject(@"CONNECT_ERROR",
+           [NSString stringWithFormat:@"VPN connectFromJSON: %@", err.localizedDescription ?: @"not a JSON object"],
+           nil);
+    return;
+  }
+  [self wireGuardConnectWithDictionary:(NSDictionary *)parsed resolver:resolve rejecter:reject];
+}
